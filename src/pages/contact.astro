---
import Layout from '../layouts/Layout.astro';

const email = 'sabarish.sivanath@outlook.com';
const phoneHref = 'tel:9145360485';
const phoneDisplay = '(914) 536-0485';
---

<Layout
	title="Contact | Sabarish"
	description="Contact Sabarish for machine learning systems, robotics, and multimodal AI work."
>
	<main class="contact-shell">
		<section class="contact-hero panel reveal">
			<div class="contact-copy">
				<p class="kicker">Contact</p>
				<h1>Reach Sabarish directly.</h1>
				<p class="lede">
					For machine learning systems, robotics, or multimodal AI work, email or call
					directly.
				</p>
			</div>
			<div class="contact-note">
				<p class="note-label">Best route</p>
				<p>Email is the cleanest path for project details. Phone works for direct follow-up.</p>
			</div>
		</section>

		<section class="contact-grid reveal">
			<a class="panel contact-card" href={`mailto:${email}`}>
				<p class="card-label">Email</p>
				<h2>{email}</h2>
				<p>Open your mail client and send a note.</p>
			</a>

			<a class="panel contact-card" href={phoneHref}>
				<p class="card-label">Phone</p>
				<h2>{phoneDisplay}</h2>
				<p>Call directly for a faster back-and-forth.</p>
			</a>
		</section>
	</main>
</Layout>

<style>
	.contact-shell {
		width: min(calc(100% - 2rem), var(--content-width));
		margin: 0 auto;
		padding: 1.5rem 0 3rem;
	}

	.panel {
		background: var(--surface);
		backdrop-filter: blur(18px);
		border: 1px solid var(--border);
		border-radius: 28px;
		box-shadow: var(--shadow);
	}

	.contact-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(16rem, 0.85fr);
		gap: 2rem;
		padding: 3rem clamp(1.5rem, 4vw, 3rem);
	}

	.kicker,
	.note-label,
	.card-label {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.72rem;
		color: var(--accent);
	}

	h1,
	h2 {
		margin: 0;
		font-family: var(--serif);
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	h1 {
		margin-top: 0.75rem;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.96;
		max-width: 10ch;
	}

	h2 {
		margin-top: 0.75rem;
		font-size: clamp(1.7rem, 3vw, 2.5rem);
		line-height: 1.06;
	}

	.lede,
	.contact-note p:last-child,
	.contact-card p:last-child {
		margin: 0;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.lede {
		margin-top: 1.5rem;
		max-width: 36rem;
	}

	.contact-note {
		align-self: start;
		padding: 1.25rem;
		background: rgba(255, 248, 240, 0.7);
		border: 1px solid rgba(63, 41, 24, 0.08);
		border-radius: 22px;
	}

	.contact-note p:last-child {
		margin-top: 0.8rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.contact-card {
		padding: 1.7rem;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.contact-card:hover {
		transform: translateY(-2px);
		background: rgba(255, 251, 246, 0.88);
		border-color: rgba(157, 75, 43, 0.18);
	}

	.reveal {
		animation: rise 700ms ease both;
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(18px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 900px) {
		.contact-hero,
		.contact-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.contact-shell {
			width: min(calc(100% - 1rem), var(--content-width));
			padding: 0.5rem 0 2rem;
		}

		.contact-hero,
		.contact-card {
			padding: 1.3rem;
			border-radius: 22px;
		}

		.lede,
		.contact-note p:last-child,
		.contact-card p:last-child {
			font-size: 0.98rem;
		}
	}
</style>
