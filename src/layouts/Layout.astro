---
interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = 'Portfolio for Sabarish Kuduwa Sivanath, Senior Machine Learning Engineer.',
} = Astro.props;
const pathname = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, '')}`;
const normalizePath = (path: string) => {
	if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
	return path;
};
const basePrefix = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
const currentPath = normalizePath(
	basePrefix !== '/' && pathname.startsWith(basePrefix) ? pathname.slice(basePrefix.length) || '/' : pathname
);
const navItems = [
	{ path: '/', label: 'Home' },
	{ path: '/blog', label: 'Blog' },
	{ path: '/contact', label: 'Contact' },
];
const isNavActive = (path: string) => {
	if (path === '/') return currentPath === '/';
	return currentPath === path || currentPath.startsWith(`${path}/`);
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
			<header class="site-header">
				<div class="site-header-inner">
					<a class="brand-mark" href={withBase('/')}>Sabarish</a>
					<nav class="site-nav" aria-label="Primary">
						{
							navItems.map((item) => (
								<a
									href={withBase(item.path)}
									class:list={['nav-link', { active: isNavActive(item.path) }]}
									aria-current={isNavActive(item.path) ? 'page' : undefined}
								>
									{item.label}
								</a>
							))
						}
				</nav>
			</div>
		</header>
		<slot />
		<footer class="site-footer">
			<div class="site-footer-inner">
				<p class="footer-copy">ML systems, robotics, and multimodal AI.</p>
				<div class="footer-links">
					<a href="mailto:sabarish.sivanath@outlook.com">sabarish.sivanath@outlook.com</a>
					<a href="tel:9145360485">(914) 536-0485</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--page-bg: #f3ede3;
		--page-bg-strong: #e6d9c5;
		--surface: rgba(255, 251, 246, 0.74);
		--surface-strong: rgba(255, 248, 240, 0.9);
		--border: rgba(63, 41, 24, 0.12);
		--text: #1e1a17;
		--muted: #5f564f;
		--accent: #9d4b2b;
		--accent-soft: #d98e66;
		--shadow: 0 22px 60px rgba(72, 43, 15, 0.12);
		--content-width: 1120px;
		--sans:
			'Avenir Next', 'Segoe UI', 'Helvetica Neue', 'Nimbus Sans', 'Liberation Sans',
			sans-serif;
		--serif: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		font-family: var(--sans);
		color: var(--text);
		background:
			radial-gradient(circle at top left, rgba(217, 142, 102, 0.32), transparent 36%),
			radial-gradient(circle at top right, rgba(82, 107, 81, 0.16), transparent 28%),
			linear-gradient(180deg, #f9f3ea 0%, var(--page-bg) 55%, var(--page-bg-strong) 100%);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	::selection {
		background: rgba(157, 75, 43, 0.18);
	}

	.site-header,
	.site-footer {
		width: min(calc(100% - 2rem), var(--content-width));
		margin: 0 auto;
	}

	.site-header {
		padding-top: 1rem;
	}

	.site-header-inner,
	.site-footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		background: rgba(255, 251, 246, 0.5);
		backdrop-filter: blur(14px);
		border: 1px solid rgba(63, 41, 24, 0.08);
		border-radius: 20px;
		box-shadow: 0 18px 40px rgba(72, 43, 15, 0.06);
	}

	.brand-mark {
		font-family: var(--serif);
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.site-nav,
	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.nav-link,
	.footer-links a {
		padding: 0.55rem 0.85rem;
		border-radius: 999px;
		color: var(--muted);
		transition:
			background-color 180ms ease,
			color 180ms ease;
	}

	.nav-link:hover,
	.footer-links a:hover {
		background: rgba(157, 75, 43, 0.08);
		color: var(--text);
	}

	.nav-link.active {
		background: rgba(157, 75, 43, 0.14);
		color: var(--text);
	}

	.site-footer {
		padding-bottom: 2rem;
	}

	.footer-copy {
		margin: 0;
		color: var(--muted);
	}

	@media (max-width: 640px) {
		.site-header,
		.site-footer {
			width: min(calc(100% - 1rem), var(--content-width));
		}

		.site-header-inner,
		.site-footer-inner {
			align-items: flex-start;
			flex-direction: column;
			padding: 0.9rem 1rem;
		}
	}
	</style>
